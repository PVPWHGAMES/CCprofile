      "Bash(rm -rf ~/Videos)",
      "Bash(rm -rf ~/Music)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /c/Users/pvp/.claude)",
      "Bash(rm -rf /c/Users/pvp/.ssh)",
      "Bash(rm -rf /c/Users/pvp/Desktop)",
      "Bash(rm -rf /c/Users/pvp/Documents)",
      "Bash(rm -rf /c/Users/pvp/Downloads)",
      "Bash(rm -r /)",
      "Bash(rm -r ~)",
      "Bash(rm -r ~/.claude)",
      "Bash(rm -r ~/.ssh)",
      "Bash(rm -r ~/Desktop)",
      "Bash(rm -r ~/Documents)",
      "Bash(rm -r ~/Downloads)",
      "Bash(rmdir ~)",
      "Bash(rmdir /)",
      "Bash(rmdir ~/.claude)",
      "Bash(rmdir ~/.ssh)",
      "Bash(rmdir ~/Desktop)",
      "Bash(rmdir ~/Documents)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "ccstatusline-zh",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  },
  "theme": "dark"
}