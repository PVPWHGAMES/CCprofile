      "Bash(java *)",
      "Bash(javac *)",
      "Bash(mvn *)",
      "Bash(gradle *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(cd *)",
      "Bash(source *)",
      "Bash(export *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(ping *)",
      "Bash(nslookup *)",
      "Bash(dig *)",
      "Bash(ifconfig *)",
      "Bash(ipconfig *)",
      "Bash(netstat *)",
      "Bash(ss *)",
      "Bash(ps *)",
      "Bash(top *)",
      "Bash(htop *)",
