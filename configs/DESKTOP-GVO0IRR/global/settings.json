      "Bash(rm -rf /bin)",
      "Bash(rm -rf /sbin)",
      "Bash(rm -rf /lib)",
      "Bash(rm -rf /root)",
      "Bash(rm -rf C:/Windows)",
      "Bash(rm -rf C:/Program Files)",
      "Bash(rm -rf C:/Program Files (x86))",
      "Bash(rm -rf ~/.claude)",
      "Bash(rm -rf ~/.ssh)",
